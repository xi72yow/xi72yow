---
import { SITE, QUOTES } from "../config";

// Pick a random quote at build time
const randomQuote = QUOTES[Math.floor(Math.random() * QUOTES.length)];
---

<footer>
  <div class="divider-gradient"></div>
  <div class="max-w-5xl mx-auto px-6 py-12 flex flex-col gap-8">
    <!-- Random movie quote -->
    <div class="text-center py-4">
      <blockquote class="text-[#fb0] text-2xl font-brand italic leading-relaxed">
        &ldquo;{randomQuote[1]}&rdquo;
      </blockquote>
      <p class="mt-2 text-[#a7a7a7] text-sm font-mono">&mdash; {randomQuote[0]}</p>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6">
        <a
          href={SITE.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#a7a7a7] hover:text-[#fb0] transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </a>
        <a
          href={SITE.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#a7a7a7] hover:text-[#fb0] transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="text-[#a7a7a7] hover:text-[#fb0] transition-colors"
          aria-label="Email"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
      </div>

      <!-- Animated SVG Logo with glitch -->
      <div class="glitch-logo">
        <img src="/assets/logo_ani.svg" alt={SITE.alias} class="h-16" />
      </div>

      <div class="flex items-center gap-3 text-sm text-[#a7a7a7]">
        <span>{SITE.alias} &middot; {SITE.domain}</span>
        <span>&middot;</span>
        <a href="https://reinke.ing" target="_blank" rel="noopener noreferrer" class="hover:text-[#fb0] transition-colors">reinke.ing</a>
        <span>&middot;</span>
        <a href="/impressum" class="hover:text-[#fb0] transition-colors">Impressum</a>
      </div>
    </div>
  </div>
</footer>

<!-- Glitch clip-path animation for logo -->
<script is:inline>
!function(){
  function rnd(){return(Math.random()*100).toFixed()}
  function poly(){var s=new Set;for(var i=0;i<=25;i++)s.add(rnd()+"% "+rnd()+"%");return Array.from(s).join(",")}
  var css="@keyframes glitchClip{4%{clip-path:polygon("+poly()+");}27%{clip-path:polygon("+poly()+");}69%{clip-path:polygon("+poly()+");}91%{clip-path:polygon("+poly()+");}5%,28%,70%,92%{clip-path:none;}}";
  var style=document.createElement("style");
  style.appendChild(document.createTextNode(css));
  document.head.appendChild(style);
}()
</script>

<style>
  .glitch-logo img {
    animation: glitchClip 7s step-end infinite;
  }
</style>
