---
import ProjectCard from "./ProjectCard.astro";
import GlitchHeadline from "./GlitchHeadline.astro";
import reposData from "../../../repos.json";

const repos = reposData.repos;
---

<section id="projects" class="section-container">
  <GlitchHeadline
    title="Projects"
    subtitle="Open-source work and side projects"
  />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {repos.map((repo) => (
      <ProjectCard
        name={repo.name}
        url={repo.url}
        description={repo.description_en_casual ?? repo.description_en}
        readmeTeaser={repo.readme_teaser}
        techStack={repo.tech_stack}
        image={repo.image}
        video={repo.video}
        isFork={repo.is_fork}
        commits={repo.last_commits}
      />
    ))}
  </div>
</section>
