---
import { SITE } from "../config";
---

<section class="section-container min-h-[80vh] mb-32 md:mb-48 flex items-center">
  <div class="flex flex-col md:flex-row items-center gap-12 w-full">
    <div class="flex-1 space-y-6">
      <p id="hero-typing" class="text-lg sm:text-xl font-mono accent tracking-wider uppercase hero-fade hero-fade-1">heydidudi my friend!</p>

      <!-- Logo with flicker -->
      <div class="hero-fade hero-fade-2">
        <img
          src="/assets/logo.webp"
          alt={SITE.alias}
          class="h-16 sm:h-20 md:h-24 logo-flicker"
        />
      </div>

      <p class="text-2xl sm:text-3xl text-secondary font-500 hero-fade hero-fade-3">
        {SITE.title}
      </p>
      <p class="text-sm sm:text-base text-secondary leading-relaxed max-w-lg hero-fade hero-fade-3">
        {SITE.catchphrase}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-4 hero-fade hero-fade-4">
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-[#af0069] to-[#fb0] text-white rounded-[6px] font-600 text-sm uppercase tracking-[0.1em] hover:shadow-[0_1.5rem_2.8rem_rgba(175,0,105,0.4),0_1rem_1rem_rgba(255,187,0,0.2)] hover:translate-y-[-2px] transition-all duration-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Get in touch
        </a>
        <a
          href="#projects"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-[#fb0] rounded-[6px] font-600 text-sm uppercase tracking-[0.1em] hover:bg-[rgba(255,187,0,0.1)] transition-all duration-200"
        >
          View projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
    <div class="flex-shrink-0 hero-fade hero-fade-3">
      <img
        src={SITE.photoUrl}
        alt={SITE.name}
        class="w-56 sm:w-64 md:w-80 lg:w-96 mx-auto drop-shadow-[0_0_20px_rgba(175,0,105,0.3)]"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero-fade {
    opacity: 0;
    transform: translateY(16px);
    animation: heroFadeIn 0.6s ease-out forwards;
  }
  .hero-fade-1 { animation-delay: 0.1s; }
  .hero-fade-2 { animation-delay: 0.25s; }
  .hero-fade-3 { animation-delay: 0.4s; }
  .hero-fade-4 { animation-delay: 0.55s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .logo-flicker {
    animation: flicker 10s linear infinite;
  }
</style>

<style is:global>
  .hero-cursor {
    display: inline-block;
    width: 0.6ch;
    height: 1.15em;
    background: #fb0;
    margin-left: 1px;
    vertical-align: text-bottom;
    animation: heroBlink 1s step-end infinite;
  }
  @keyframes heroBlink {
    50% { opacity: 0; }
  }
</style>

<script>
  function initHeroTyping() {
    const el = document.getElementById("hero-typing");
    if (!el) return;

    let typingStarted = false;

    function onSeason(season: string) {
      if (season === "birthday" && !typingStarted) {
        typingStarted = true;
        setTimeout(() => heroTypeSequence(el), 1750);
      } else if (season !== "birthday") {
        el.textContent = "heydidudi my friend!";
      }
    }

    window.addEventListener("season-change", ((e: CustomEvent) => {
      onSeason(e.detail);
    }) as EventListener);
  }

  async function heroTypeSequence(el: HTMLElement) {
    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));
    const typeDelay = () => 70 + Math.random() * 80;
    const delDelay = () => 60 + Math.random() * 50;

    const cursor = document.createElement("span");
    cursor.className = "hero-cursor";
    el.textContent = "";
    el.appendChild(cursor);

    const typeStr = async (s: string) => {
      for (const ch of s) { cursor.before(ch); await delay(typeDelay()); }
    };
    const delChars = async (n: number) => {
      for (let d = 0; d < n; d++) {
        const t = cursor.previousSibling;
        if (t && t.nodeType === Node.TEXT_NODE) {
          t.textContent = t.textContent!.slice(0, -1);
          if (t.textContent === "") t.remove();
        }
        await delay(delDelay());
      }
    };

    // 1. type "heydidudi my friend!"
    await typeStr("heydidudi my friend!");

    await delay(800 + Math.random() * 400);

    // delete "friend!"
    await delChars("friend!".length);
    await delay(300 + Math.random() * 200);

    // 2. type "good lo" — aborted typo
    await typeStr("good lo");
    await delay(400 + Math.random() * 300);
    await delChars("good lo".length);
    await delay(250 + Math.random() * 150);

    // 3. type "charmant" — french detour
    await typeStr("charmant");
    await delay(600 + Math.random() * 400);
    await delChars("charmant".length);
    await delay(250 + Math.random() * 150);

    // 4. type "brilliant friend!" — final
    await typeStr("brilliant friend!");
    await delay(500);
    cursor.remove();

  }

  initHeroTyping();
  document.addEventListener("astro:page-load", initHeroTyping);
</script>
