---
interface Commit {
  message: string;
  date: string;
  author: string;
}

interface Props {
  name: string;
  url: string;
  description: string;
  readmeTeaser: string | null;
  techStack: string[];
  image: string | null;
  video: string | null;
  isFork: boolean;
  commits: Commit[];
}

const { name, url, description, readmeTeaser, techStack, image, video, isFork, commits } = Astro.props;
const localImage = image ? `/images/${name}.webp` : null;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function shortMessage(msg: string): string {
  const firstLine = msg.split("\n")[0];
  return firstLine.length > 72 ? firstLine.slice(0, 69) + "..." : firstLine;
}

const badgeColors: Record<string, string> = {
  TypeScript: "bg-blue-900/60 text-blue-300 border border-blue-700/40",
  JavaScript: "bg-yellow-900/60 text-yellow-300 border border-yellow-700/40",
  Rust: "bg-orange-900/60 text-orange-300 border border-orange-700/40",
  C: "bg-gray-800/60 text-gray-300 border border-gray-600/40",
  Shell: "bg-green-900/60 text-green-300 border border-green-700/40",
  Dockerfile: "bg-cyan-900/60 text-cyan-300 border border-cyan-700/40",
  SCSS: "bg-pink-900/60 text-pink-300 border border-pink-700/40",
};

function getBadgeClass(tech: string): string {
  return badgeColors[tech] || "bg-neutral-800/60 text-neutral-300 border border-neutral-600/40";
}
---

<article class="card overflow-hidden hover:shadow-[0_0_30px_rgba(175,0,105,0.3),0_0_60px_rgba(255,187,0,0.1)] hover:border-[#af0069] transition-all duration-300 group flex flex-col">
  {video ? (
    <div class="aspect-video bg-[rgba(0,0,0,0.3)] overflow-hidden relative video-container cursor-pointer" data-video-src={video}>
      {localImage ? (
        <img
          src={localImage}
          alt={name}
          class="w-full h-full object-cover video-thumb"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center video-thumb">
          <span class="text-muted text-sm font-mono">{name}</span>
        </div>
      )}
      <div class="video-play-overlay absolute inset-0 flex flex-col items-center justify-center bg-black/30 hover:bg-black/50 transition-colors">
        <svg class="w-14 h-14 text-white drop-shadow-lg hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z" />
        </svg>
        <span class="text-white/60 text-xs mt-2 drop-shadow">Click loads video from GitHub</span>
      </div>
    </div>
  ) : localImage ? (
    <div class="aspect-video bg-[rgba(0,0,0,0.3)] overflow-hidden">
      <img
        src={localImage}
        alt={name}
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
        loading="lazy"
      />
    </div>
  ) : null}

  <div class="p-6 flex flex-col flex-1 gap-4">
    <div class="space-y-4">
    <div class="flex items-center gap-3">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-lg font-700 hover:text-[#fb0] transition-colors"
      >
        {name}
      </a>
      {isFork && (
        <span class="text-xs px-2 py-0.5 rounded-full bg-[rgba(255,255,255,0.05)] text-[#a7a7a7] font-mono">
          fork
        </span>
      )}
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="ml-auto text-neutral-500 hover:text-neutral-300 transition-colors"
        aria-label={`View ${name} on GitHub`}
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
      </a>
    </div>

    <p class="text-sm text-neutral-400 leading-relaxed">
      {description}
    </p>

    {readmeTeaser && (
      <div class="readme-teaser">
        <p class="text-xs text-neutral-500 leading-relaxed">
          {readmeTeaser}
        </p>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="readme-teaser-link text-xs font-mono accent hover:underline"
        >
          Read more on GitHub →
        </a>
      </div>
    )}

    </div>

    <div class="mt-auto space-y-4">
    <div class="flex flex-wrap gap-1.5">
      {techStack.map((tech) => (
        <span class={`text-xs font-mono px-2 py-0.5 rounded-md ${getBadgeClass(tech)}`}>
          {tech}
        </span>
      ))}
    </div>

    {commits.length > 0 && (
      <details class="pt-2">
        <summary class="text-xs font-mono text-neutral-500 cursor-pointer hover:text-neutral-300 transition-colors select-none">
          Recent commits
        </summary>
        <ul class="mt-2 space-y-1.5">
          {commits.map((commit) => (
            <li class="text-xs flex gap-2">
              <span class="text-neutral-500 font-mono whitespace-nowrap shrink-0">
                {formatDate(commit.date)}
              </span>
              <span class="text-neutral-400 truncate">
                {shortMessage(commit.message)}
              </span>
            </li>
          ))}
        </ul>
      </details>
    )}
    </div>
  </div>
</article>

<script>
  document.querySelectorAll('.video-container').forEach((container) => {
    container.addEventListener('click', () => {
      const src = container.getAttribute('data-video-src');
      if (!src) return;
      const video = document.createElement('video');
      video.src = src;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.autoplay = true;
      video.className = 'w-full h-full object-cover';
      container.innerHTML = '';
      container.classList.remove('cursor-pointer');
      container.appendChild(video);
      video.play();
    });
  });
</script>

<style>
  .readme-teaser {
    position: relative;
  }
  .readme-teaser p {
    max-height: 3rem;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
  }
  .readme-teaser-link {
    position: relative;
    display: inline-block;
    margin-top: 0.25rem;
  }
</style>
