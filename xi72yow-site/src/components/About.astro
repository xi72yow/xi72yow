---
import GlitchHeadline from "./GlitchHeadline.astro";
import reposData from "../../../repos.json";

const profile = reposData.profile;
const paragraphs = profile?.about_en ?? [];
const langStats = profile?.language_stats ?? [];

const langColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f1e05a",
  Rust: "#dea584",
  C: "#555555",
  Shell: "#89e051",
  SCSS: "#c6538c",
  Dockerfile: "#384d54",
  HTML: "#e34c26",
  CSS: "#563d7c",
  Python: "#3572A5",
  Go: "#00ADD8",
};
---

<section id="about" class="section-container">
  <div class="divider-gradient mb-10 md:mb-20"></div>

  <GlitchHeadline
    title="About"
    subtitle="Background and stats"
  />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
    <div class="space-y-4 text-secondary leading-relaxed">
      {paragraphs.map((text) => (
        <p>{text}</p>
      ))}
    </div>

    <div class="space-y-5">
      <h3 class="label font-brand">Code</h3>

      <!-- Stacked bar -->
      <div class="flex w-full h-3 rounded-[4px] overflow-hidden">
        {langStats.map((lang) => (
          <div
            style={`width: ${lang.percentage}%; background: ${langColors[lang.name] || "#6b7280"}`}
            title={`${lang.name}: ${lang.percentage}%`}
          />
        ))}
      </div>

      <!-- Legend -->
      <div class="space-y-2.5">
        {langStats.map((lang) => (
          <div class="flex items-center justify-between text-sm">
            <div class="flex items-center gap-2">
              <span
                class="w-3 h-3 rounded-[4px] inline-block flex-shrink-0"
                style={`background: ${langColors[lang.name] || "#6b7280"}`}
              />
              <span class="text-neutral-300">{lang.name}</span>
            </div>
            <span class="text-[#a7a7a7] font-mono text-xs">{lang.percentage}%</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
