---
import GlitchHeadline from "./GlitchHeadline.astro";
import reposData from "../../../repos.json";

const profile = reposData.profile;
const paragraphs = profile?.about_en ?? [];
const langStats = profile?.language_stats ?? [];

const langColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f1e05a",
  Rust: "#dea584",
  C: "#555555",
  Shell: "#89e051",
  SCSS: "#c6538c",
  Dockerfile: "#384d54",
  HTML: "#e34c26",
  CSS: "#563d7c",
  Python: "#3572A5",
  Go: "#00ADD8",
};
---

<section id="about" class="section-container">
  <div class="divider-gradient mb-10 md:mb-20"></div>

  <GlitchHeadline
    title="About"
    subtitle="Background and stats"
  />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
    <div id="about-text" class="space-y-4 text-secondary leading-relaxed">
      {paragraphs.map((text) => (
        <p>{text}</p>
      ))}
    </div>

    <div class="space-y-5">
      <h3 class="label font-brand">Code</h3>

      <!-- Stacked bar -->
      <div id="lang-bar" class="flex w-full h-3 rounded-[4px] overflow-hidden">
        {langStats.map((lang) => (
          <div
            class="lang-segment"
            style={`width: 0%; background: ${langColors[lang.name] || "#6b7280"}`}
            data-target-width={lang.percentage}
            title={`${lang.name}: ${lang.percentage}%`}
          />
        ))}
      </div>

      <!-- Legend -->
      <div id="lang-legend" class="space-y-2.5">
        {langStats.map((lang) => (
          <div class="lang-legend-item flex items-center justify-between text-sm">
            <div class="flex items-center gap-2">
              <span
                class="w-3 h-3 rounded-[4px] inline-block flex-shrink-0"
                style={`background: ${langColors[lang.name] || "#6b7280"}`}
              />
              <span class="text-neutral-300">{lang.name}</span>
            </div>
            <span class="text-[#a7a7a7] font-mono text-xs">{lang.percentage}%</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .lang-segment {
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .lang-legend-item {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
  .lang-legend-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  async function revealLangs() {
    const bar = document.getElementById("lang-bar");
    const segments = bar?.querySelectorAll<HTMLElement>(".lang-segment") ?? [];
    const legendItems = document.querySelectorAll<HTMLElement>(".lang-legend-item");
    const count = Math.max(segments.length, legendItems.length);
    const delay = (ms: number) => new Promise((r) => setTimeout(r, ms));

    await delay(1000);
    for (let i = 0; i < count; i++) {
      const pct = parseFloat(segments[i]?.dataset.targetWidth || "0");
      // under 2%: scale down duration proportionally, min 150ms
      const wait = pct >= 2 ? 1400 : Math.max(150, 1400 * (pct / 2));
      if (segments[i]) segments[i].style.width = `${pct}%`;
      if (legendItems[i]) legendItems[i].classList.add("visible");
      await delay(wait);
    }
  }

  function initAboutSection() {
    const section = document.getElementById("about");
    if (!section) return;

    const isDesktop = window.matchMedia("(min-width: 768px)").matches;
    let started = false;

    if (isDesktop) {
      // desktop: sequenced — bar → legend
      const observer = new IntersectionObserver(
        async (entries) => {
          if (entries[0].isIntersecting && !started) {
            started = true;
            observer.disconnect();
            await revealLangs();
          }
        },
        { threshold: 0.2 }
      );
      observer.observe(section);
    } else {
      // mobile: independent observers (elements stacked vertically)
      let barStarted = false;
      const barObs = new IntersectionObserver(
        async (entries) => {
          if (entries[0].isIntersecting && !barStarted) {
            barStarted = true;
            barObs.disconnect();
            revealLangs();
          }
        },
        { threshold: 0.3 }
      );
      const bar = document.getElementById("lang-bar");
      if (bar) barObs.observe(bar);

    }
  }

  initAboutSection();
  document.addEventListener("astro:page-load", initAboutSection);
</script>
