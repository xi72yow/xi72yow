---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title={post.data.title}>
  <main class="min-h-screen pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-6 w-full">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-[#a7a7a7] hover:text-[#fb0] transition-colors mb-12 group"
      >
        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="text-lg font-mono">Blog</span>
      </a>

      <h1 class="text-4xl sm:text-5xl font-700 mb-4">{post.data.title}</h1>

      <div class="flex flex-wrap items-center gap-2 mb-8">
        {post.data.tags.map((tag) => (
          <span class="text-sm font-mono px-3 py-1 rounded-md bg-neutral-800/60 text-neutral-400 border border-neutral-600/40">
            {tag}
          </span>
        ))}
        <time class="text-sm font-mono text-neutral-500 ml-auto">
          {formatDate(post.data.date)}
        </time>
      </div>

      <article class="prose">
        <Content />
      </article>
    </div>
  </main>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll(".prose pre").forEach(function(pre) {
        var wrapper = document.createElement("div");
        wrapper.className = "code-glow";
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
      });
      var blocks = document.querySelectorAll('pre[data-language="mermaid"]');
      if (!blocks.length) return;
      var s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js";
      s.onload = function() {
        mermaid.initialize({ startOnLoad: false, theme: "dark" });
        blocks.forEach(function(pre) {
          var div = document.createElement("div");
          div.className = "mermaid";
          div.textContent = pre.textContent;
          pre.replaceWith(div);
        });
        mermaid.run();
      };
      document.head.appendChild(s);
    });
  </script>
</Base>

<style is:global>
  .prose {
    color: #d4d4d4;
    max-width: none;
    line-height: 1.75;
  }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    color: #f5f5f5;
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.75em;
  }
  .prose h1 { font-size: 1.75rem; }
  .prose h2 { font-size: 1.5rem; }
  .prose h3 { font-size: 1.25rem; }
  .prose p { margin-bottom: 1em; }
  .prose a {
    color: #fb0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover { color: #af0069; }
  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5em 0;
  }
  .prose code {
    font-size: 0.875em;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    background: rgb(255 255 255 / 0.1);
  }
  .prose pre {
    overflow-x: auto;
    padding: 1.25em;
    margin: 1.5em 0;
    background: transparent !important;
  }
  .prose .code-glow {
    position: relative;
    z-index: 0;
  }
  .prose .code-glow::before {
    content: "";
    position: absolute;
    inset: 1rem 0.5rem;
    background: rgba(0, 0, 0, 0.4);
    box-shadow: 0 0 2rem 2rem rgba(0, 0, 0, 0.4);
    border-radius: 1rem;
    pointer-events: none;
    z-index: -1;
  }
  .prose pre code {
    padding: 0;
    background: none;
  }
  .prose ul, .prose ol {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }
  .prose ul { list-style-type: disc; }
  .prose ol { list-style-type: decimal; }
  .prose li { margin-bottom: 0.25em; }
  .prose blockquote {
    border-left: 3px solid rgb(255 255 255 / 0.2);
    padding-left: 1em;
    margin: 1.5em 0;
    font-style: italic;
    opacity: 0.85;
  }
  .prose hr {
    border: none;
    border-top: 1px solid rgb(255 255 255 / 0.1);
    margin: 2em 0;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
  }
  .prose th, .prose td {
    border: 1px solid rgb(255 255 255 / 0.1);
    padding: 0.5em 0.75em;
    text-align: left;
  }
  .prose th { font-weight: 600; }
  .prose .mermaid {
    margin: 2.5em 0;
    text-align: center;
  }
</style>
