---
import Base from "../../layouts/Base.astro";
import { SITE } from "../../config";
import { getCollection, render } from "astro:content";
import reposData from "../../../../repos.json";

export async function getStaticPaths() {
  const readmes = await getCollection("readmes");
  const readmeMap = Object.fromEntries(readmes.map((r) => [r.id, r]));
  return reposData.repos.map((repo: any) => ({
    params: { slug: repo.name },
    props: { repo, readmeEntry: readmeMap[repo.name] || null },
  }));
}

const { repo, readmeEntry } = Astro.props;
let Content: any = null;
if (readmeEntry) {
  const rendered = await render(readmeEntry);
  Content = rendered.Content;
}

const localImage = repo.image ? `/images/${repo.name}.webp` : null;

const badgeColors: Record<string, string> = {
  TypeScript: "bg-blue-900/60 text-blue-300 border border-blue-700/40",
  JavaScript: "bg-yellow-900/60 text-yellow-300 border border-yellow-700/40",
  Rust: "bg-orange-900/60 text-orange-300 border border-orange-700/40",
  C: "bg-gray-800/60 text-gray-300 border border-gray-600/40",
  Shell: "bg-green-900/60 text-green-300 border border-green-700/40",
  Dockerfile: "bg-cyan-900/60 text-cyan-300 border border-cyan-700/40",
  SCSS: "bg-pink-900/60 text-pink-300 border border-pink-700/40",
};

function getBadgeClass(tech: string): string {
  return badgeColors[tech] || "bg-neutral-800/60 text-neutral-300 border border-neutral-600/40";
}
---

<Base title={repo.name}>
  <main class="min-h-screen pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-6 w-full">
      <a
        href="/#projects"
        class="inline-flex items-center gap-2 text-[#a7a7a7] hover:text-[#fb0] transition-colors mb-12 group"
      >
        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="text-lg font-mono">Projects</span>
      </a>

      {localImage && (
        <div class="aspect-video rounded-xl overflow-hidden mb-8 bg-[rgba(0,0,0,0.3)]">
          <img src={localImage} alt={repo.name} class="w-full h-full object-cover" />
        </div>
      )}

      <h1 class="text-4xl sm:text-5xl font-700 mb-4">{repo.name}</h1>

      <p class="text-neutral-400 leading-relaxed mb-2">
        {repo.description_en}
      </p>

      <div class="flex flex-wrap items-center gap-3 mb-8">
        {repo.tech_stack.map((tech: string) => (
          <span class={`text-xs font-mono px-2 py-0.5 rounded-md ${getBadgeClass(tech)}`}>
            {tech}
          </span>
        ))}
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm text-[#a7a7a7] hover:text-[#fb0] transition-colors ml-auto"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          GitHub
        </a>
        {repo.homepage && (
          <a
            href={repo.homepage}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-[#a7a7a7] hover:text-[#fb0] transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Live
          </a>
        )}
      </div>

      {Content && (
        <div class="border-t border-neutral-700/50 pt-8">
          <article class="prose">
            <Content />
          </article>
        </div>
      )}
    </div>
  </main>
  <script is:inline>
    var copySvg = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 8m0 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8v-2a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>';
    var checkSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5l10-10"/></svg>';
    function initProjectPage() {
      document.querySelectorAll(".prose pre:not(.code-glow pre)").forEach(function(pre) {
        var wrapper = document.createElement("div");
        wrapper.className = "code-glow";
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
      });
      document.querySelectorAll(".prose pre:not([data-copy-init])").forEach(function(pre) {
        pre.dataset.copyInit = "1";
        pre.style.position = "relative";
        var btn = document.createElement("button");
        btn.className = "copy-btn";
        btn.type = "button";
        btn.innerHTML = copySvg;
        btn.addEventListener("click", function() {
          var code = pre.querySelector("code");
          navigator.clipboard.writeText((code || pre).textContent).then(function() {
            btn.innerHTML = checkSvg;
            setTimeout(function() { btn.innerHTML = copySvg; }, 1500);
          });
        });
        pre.appendChild(btn);
      });
    }
    document.addEventListener("DOMContentLoaded", initProjectPage);
    document.addEventListener("astro:page-load", initProjectPage);
    document.addEventListener("click", function(e) {
      var btn = e.target.closest(".video-consent-btn");
      if (!btn) return;
      var wrapper = btn.closest(".video-consent");
      var src = wrapper.dataset.videoSrc;
      var video = document.createElement("video");
      video.src = src;
      video.controls = true;
      video.autoplay = true;
      video.style.width = "100%";
      video.style.borderRadius = "0.5rem";
      wrapper.replaceWith(video);
    });
  </script>

</Base>

<style is:global>
  .prose {
    color: #d4d4d4;
    max-width: none;
    line-height: 1.75;
  }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    color: #f5f5f5;
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.75em;
  }
  .prose h1 { font-size: 1.75rem; }
  .prose h2 { font-size: 1.5rem; }
  .prose h3 { font-size: 1.25rem; }
  .prose p { margin-bottom: 1em; }
  .prose a {
    color: #fb0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover { color: #af0069; }
  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5em 0;
  }
  .prose code {
    font-size: 0.875em;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    background: rgb(255 255 255 / 0.1);
  }
  .prose pre {
    overflow-x: auto;
    padding: 1.25em;
    margin: 1.5em 0;
    background: transparent !important;
  }
  .prose .code-glow {
    position: relative;
    z-index: 0;
  }
  .prose .code-glow::before {
    content: "";
    position: absolute;
    inset: 1rem 0.5rem;
    background: rgba(0, 0, 0, 0.4);
    box-shadow: 0 0 2rem 2rem rgba(0, 0, 0, 0.4);
    border-radius: 1rem;
    pointer-events: none;
    z-index: -1;
  }
  .prose pre code {
    padding: 0;
    background: none;
  }
  .prose pre .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgb(0 0 0 / 0.3);
    border: none;
    border-radius: 0.25rem;
    color: rgb(255 255 255 / 0.5);
    cursor: pointer;
    padding: 0.25rem;
    line-height: 0;
    opacity: 0;
    transition: opacity 0.2s, color 0.2s;
  }
  .prose pre:hover .copy-btn { opacity: 1; }
  .prose pre .copy-btn:hover { color: rgb(255 255 255 / 0.9); }
  .prose ul, .prose ol {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }
  .prose ul { list-style-type: disc; }
  .prose ol { list-style-type: decimal; }
  .prose li { margin-bottom: 0.25em; }
  .prose blockquote {
    border-left: 3px solid rgb(255 255 255 / 0.2);
    padding-left: 1em;
    margin: 1.5em 0;
    font-style: italic;
    opacity: 0.85;
  }
  .prose hr {
    border: none;
    border-top: 1px solid rgb(255 255 255 / 0.1);
    margin: 2em 0;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
  }
  .prose th, .prose td {
    border: 1px solid rgb(255 255 255 / 0.1);
    padding: 0.5em 0.75em;
    text-align: left;
  }
  .prose th { font-weight: 600; }
  .prose details { margin: 1em 0; }
  .prose summary { cursor: pointer; font-weight: 600; }
  .prose video {
    max-width: 100%;
    border-radius: 0.5rem;
    margin: 1.5em 0;
  }
  .prose .mermaid {
    margin: 2.5em 0;
    text-align: center;
    overflow-x: auto;
  }
  .prose .mermaid svg {
    max-width: 100%;
    height: auto;
    background: transparent !important;
  }
  .prose .video-consent {
    position: relative;
    aspect-ratio: 16 / 9;
    background: rgb(255 255 255 / 0.06);
    border-radius: 0.5rem;
    margin: 1.5em 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .prose .video-consent-overlay { text-align: center; }
  .prose .video-consent-btn {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .prose .video-consent-btn:hover { opacity: 1; }
  .prose .video-consent-notice {
    font-size: 0.75rem;
    opacity: 0.5;
    margin-top: 0.5em;
  }
</style>
