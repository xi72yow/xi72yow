---
import Base from "../layouts/Base.astro";
import { SITE } from "../config";
---

<Base title="Impressum">
  <main class="min-h-screen flex items-start justify-center pt-24 pb-16">
    <div class="max-w-2xl mx-auto px-6 w-full">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span data-i18n-en="Back" data-i18n-de="Zurück">Back</span>
      </a>

      <h1 class="text-3xl font-700 mb-8">Impressum</h1>

      <div class="space-y-6 text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
        <section>
          <h2 class="text-lg font-600 text-neutral-900 dark:text-neutral-100 mb-2">
            Angaben gemäß § 5 DDG
          </h2>
          <p>
            {SITE.name}<br />
            Marktstraße 25<br />
            99444 Blankenhain
          </p>
        </section>

        <section>
          <h2 class="text-lg font-600 text-neutral-900 dark:text-neutral-100 mb-2">Kontakt / Contact</h2>
          <p>
            E-Mail:
            <a
              href={`mailto:${SITE.email}`}
              class="accent hover:underline"
            >
              {SITE.email}
            </a>
          </p>
        </section>

        <section>
          <h2 class="text-lg font-600 text-neutral-900 dark:text-neutral-100 mb-2">
            <span data-i18n-en="Disclaimer" data-i18n-de="Haftungsausschluss">Disclaimer</span>
          </h2>
          <div data-lang="de" class="space-y-2 hidden">
            <p>
              <strong>Haftung für Inhalte:</strong> Die Inhalte dieser Seite wurden mit größter Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte kann jedoch keine Gewähr übernommen werden.
            </p>
            <p>
              <strong>Haftung für Links:</strong> Diese Seite enthält Links zu externen Webseiten Dritter, auf deren Inhalte kein Einfluss besteht. Für die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter verantwortlich.
            </p>
          </div>
          <div data-lang="en" class="space-y-2">
            <p>
              <strong>Liability for content:</strong> The contents of this site have been created with the utmost care. However, no guarantee can be given for the correctness, completeness, and timeliness of the content.
            </p>
            <p>
              <strong>Liability for links:</strong> This site contains links to external third-party websites over whose content there is no influence. The respective provider is always responsible for the content of the linked pages.
            </p>
          </div>
        </section>
      </div>
    </div>
  </main>
</Base>
