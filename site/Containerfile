# Build context should be the parent directory:
#   docker build -f site/Containerfile -t reinke-portfolio .
# This allows access to both site/ and repos.json

FROM dhi.io/node:25-debian13-dev AS build
RUN apt-get update && apt-get install -y --no-install-recommends \
    xz-utils fontconfig chromium \
    && rm -rf /var/lib/apt/lists/*
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ADD https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-amd64-static.tar.xz /tmp/ffmpeg.tar.xz
RUN cd /tmp && tar xf ffmpeg.tar.xz && install -D ffmpeg-*-amd64-static/ffmpeg /usr/local/bin/ffmpeg && rm -rf /tmp/ffmpeg*
WORKDIR /app
COPY site/package.json site/package-lock.json* ./
RUN npm install
COPY site/ .
COPY repos.json ../repos.json
COPY blog/ ../blog/
COPY blog-de/ ../blog-de/
COPY readmes/ ../readmes/
COPY shared/ ../shared/
RUN --mount=type=cache,target=/tmp/image-cache \
    cp -r /tmp/image-cache/* public/images/ 2>/dev/null || true && \
    node scripts/fetch-images.mjs && \
    cp -r public/images/* /tmp/image-cache/
RUN rm -rf dist && npx astro build && node scripts/render-mermaid.mjs

FROM dhi.io/node:25-debian13
WORKDIR /app
COPY --from=build /app/dist ./dist
COPY site/serve.mjs ./serve.mjs
EXPOSE 3000
HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
  CMD ["node", "-e", "fetch('http://localhost:3000/').then(r=>{process.exit(r.ok?0:1)}).catch(()=>process.exit(1))"]
CMD ["node", "serve.mjs"]
